<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="shop_brand_filter"
              inherit_id="website_sale.filter_products_price"
              name="Shop sidebar brand filter">

        <xpath expr="//div[@id='o_wsale_price_range_option']" position="before">
            <div id="o_wsale_brand_option" t-attf-class="position-relative {{_classes}}">
                <t t-if="is_sidebar_collapsible">
                    <div class="accordion-item">
                        <div class="accordion-header h6 mb-0">
                            <button class="accordion-button px-0 bg-transparent shadow-none collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#o_wsale_brand_option_inner"
                                    aria-controls="o_wsale_brand_option_inner"
                                    aria-expanded="false">
                                <b>Marca</b>
                            </button>
                        </div>

                        <div id="o_wsale_brand_option_inner" class="accordion-collapse collapse">
                            <div class="accordion-body px-0">

                                <t t-set="brands"
                                   t-value="request.env['product.brand'].sudo().search([
                                       ('active', '=', True),
                                       ('product_ids.is_published', '=', True),
                                       ('product_ids.sale_ok', '=', True)
                                   ] + (category and [('product_ids.public_categ_ids', 'child_of', category.id)] or []),
                                   order='name asc')"/>

                                <t t-if="brands">
                                    <div class="mb-2">
                                        <a t-att-href="category and ('/shop/category/%s' % slug(category)) or '/shop'"
                                           t-attf-class="{{ 'fw-bold text-primary' if not request.params.get('brand') and not brand_slug else '' }}">
                                            Todas las marcas
                                        </a>
                                    </div>

                                    <ul class="list-unstyled mb-0">
                                        <t t-foreach="brands" t-as="brand">
                                            <li class="mb-1">
                                                <a t-att-href="keep(brand=brand.website_slug, page=False)"
                                                   t-attf-class="{{ 'fw-bold text-primary' if request.params.get('brand') == brand.website_slug or brand_slug == brand.website_slug else '' }}"
                                                   t-out="brand.name"/>
                                            </li>
                                        </t>
                                    </ul>
                                </t>

                            </div>
                        </div>
                    </div>
                </t>

                <t t-else="">
                    <label t-attf-class="h6 m-0 {{_classes_title}}">
                        <b>Marca</b>
                    </label>

                    <div class="mt-2">
                        <t t-set="brands"
                           t-value="request.env['product.brand'].sudo().search([
                               ('active', '=', True),
                               ('product_ids.is_published', '=', True),
                               ('product_ids.sale_ok', '=', True)
                           ] + (category and [('product_ids.public_categ_ids', 'child_of', category.id)] or []),
                           order='name asc')"/>

                        <t t-if="brands">
                            <div class="mb-2">
                                <a t-att-href="category and ('/shop/category/%s' % slug(category)) or '/shop'"
                                   t-attf-class="{{ 'fw-bold text-primary' if not request.params.get('brand') and not brand_slug else '' }}">
                                    Todas las marcas
                                </a>
                            </div>

                            <ul class="list-unstyled mb-0">
                                <t t-foreach="brands" t-as="brand">
                                    <li class="mb-1">
                                        <a t-att-href="keep(brand=brand.website_slug, page=False)"
                                           t-attf-class="{{ 'fw-bold text-primary' if request.params.get('brand') == brand.website_slug or brand_slug == brand.website_slug else '' }}"
                                           t-out="brand.name"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                    </div>
                </t>
            </div>
        </xpath>

    </template>

</odoo>