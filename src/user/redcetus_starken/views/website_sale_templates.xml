<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_sale_address_starken_commune"
              inherit_id="website_sale.address">
        <xpath expr="//form[@name='address_form']/div[contains(@class, 'row')]" position="inside">
            <div class="mb-3 col-lg-6">
                <label class="col-form-label" for="starken_commune_id">
                    Comuna (Starken)
                </label>
                <select name="starken_commune_id"
                        id="starken_commune_id"
                        class="form-select">
                    <option value="">Comuna...</option>
                    <t t-foreach="request.env['starken.commune'].sudo().search([], order='name asc')" t-as="commune">
                        <option t-att-value="commune.id">
                            <t t-esc="commune.name"/>
                        </option>
                    </t>
                </select>
            </div>
        </xpath>
    </template>
</odoo>