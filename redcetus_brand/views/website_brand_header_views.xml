<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="brand_header_on_shop"
              inherit_id="website_sale.products"
              name="Brand header on shop page">

        <xpath expr="//div[contains(@class, 'o_wsale_products_main_row')]" position="before">
            <t t-if="current_brand">
                <div class="container mb-3">

                    <div class="d-flex align-items-center gap-3 mb-2">
                        <t t-if="current_brand.image_1920">
                            <img t-att-src="'/web/image/product.brand/%s/image_1920' % current_brand.id"
                                 style="max-height:60px;"/>
                        </t>

                        <h1 class="mb-0" t-out="current_brand.name"/>
                    </div>

                    <t t-if="current_brand.description">
                        <div t-field="current_brand.description"/>
                    </t>

                </div>
            </t>
        </xpath>

    </template>

</odoo>