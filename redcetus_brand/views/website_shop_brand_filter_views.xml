<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="shop_brand_filter"
              inherit_id="website_sale.product_attribute_filters_form"
              name="Shop sidebar brand filter">

        <xpath expr="//form" position="inside">
            <div class="accordion-item">
                <div class="accordion-header h6 mb-0">
                    <button class="accordion-button collapsed px-0 bg-transparent shadow-none"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#o_products_brands"
                            aria-controls="o_products_brands"
                            aria-expanded="false">
                        <b>Marca</b>
                    </button>
                </div>
                <div id="o_products_brands"
                     class="accordion-collapse collapse"
                     data-bs-parent="wsale_products_attributes_collapse">
                    <div class="accordion-body px-0">
                        <t t-set="brands"
                           t-value="request.env['product.brand'].sudo().search([
                               ('active', '=', True),
                               ('product_ids.is_published', '=', True),
                               ('product_ids.sale_ok', '=', True)
                           ], order='name asc')"/>

                        <t t-if="brands">
                            <ul class="list-unstyled mb-0">
                                <t t-foreach="brands" t-as="brand">
                                    <li class="mb-1">
                                        <a t-att-href="'/shop/marca/%s' % brand.website_slug"
                                           t-out="brand.name"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>

    </template>

</odoo>