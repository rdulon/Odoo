<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="shop_brand_filter"
              inherit_id="website_sale.product_attribute_filters_form"
              name="Shop sidebar brand filter">

        <xpath expr="//form" position="inside">
            <div class="accordion-item">
                <div class="accordion-header h6 mb-0">
                    <button class="accordion-button collapsed px-0 bg-transparent shadow-none"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#o_products_brands"
                            aria-controls="o_products_brands"
                            aria-expanded="false">
                        <b>Marca</b>
                    </button>
                </div>
                <div id="o_products_brands"
                     class="accordion-collapse collapse"
                     data-bs-parent="wsale_products_attributes_collapse">
                    <div class="accordion-body px-0">

                        <t t-set="brand_domain"
                           t-value="[('active', '=', True),
                                     ('product_ids.is_published', '=', True),
                                     ('product_ids.sale_ok', '=', True)] +
                                    (category and [('product_ids.public_categ_ids', 'child_of', category.id)] or [])"/>

                        <t t-set="brands"
                           t-value="request.env['product.brand'].sudo().search(brand_domain, order='name asc')"/>

                        <t t-if="brands">
                            <div class="mb-2">
                                <a t-att-href="keep(brand=False, page=False)"
                                   t-attf-class="{{ '' if request.params.get('brand') else 'fw-bold text-primary' }}">
                                    Todas las marcas
                                </a>
                            </div>

                            <ul class="list-unstyled mb-0">
                                <t t-foreach="brands" t-as="brand">
                                    <li class="mb-1">
                                        <a t-att-href="keep(brand=brand.website_slug, page=False)"
                                           t-attf-class="{{ 'fw-bold text-primary' if request.params.get('brand') == brand.website_slug else '' }}"
                                           t-out="brand.name"/>
                                    </li>
                                </t>
                            </ul>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>

    </template>
</odoo>